{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$comment": "Changes here need approval from one person on each pair since it affects both categories.",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "category": {
      "type": "string",
      "enum": ["injection", "jailbreak"]
    },
    "subcategory": {
      "type": "string"
    },
    "system_prompt": {
      "type": "string"
    },
    "user_prompt": {
      "type": "string"
    },
    "injected_context": {
      "type": ["string", "null"]
    },
    "expected_behavior": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "author": {
      "type": "string"
    },
    "notes": {
      "type": ["string", "null"]
    }
  },
  "required": [
    "id",
    "category",
    "subcategory",
    "system_prompt",
    "user_prompt",
    "expected_behavior",
    "severity",
    "tags",
    "author"
  ],
  "additionalProperties": false
}
